# Web (Next.js) — variables d'environnement.
# Renseigner dans web/.env.local (gitignored). Ce fichier sert de template.
# En prod (Vercel), les mêmes variables se configurent dans le dashboard
# Project Settings → Environment Variables.

# ============================================================================
# Auth.js v5 (chantier 4, ADR-016)
# ============================================================================

# Secret de signature des cookies de session.
# Générer une chaîne aléatoire : `openssl rand -base64 32`
# En dev sans secret, Auth.js refuse de démarrer.
AUTH_SECRET=

# Email transport (magic link).
# - Sans EMAIL_SERVER : le lien magic link est loggé sur stderr (mode dev).
# - Avec EMAIL_SERVER : nodemailer envoie un vrai email.
# Format : "smtp://user:pass@host:port" (ex. Resend : smtp.resend.com:465)
# EMAIL_SERVER=smtp://resend:re_xxx@smtp.resend.com:465
# EMAIL_FROM=baloo@<ton-domaine>.fr

# ============================================================================
# BDD (chantier 7, ADR-017)
# ============================================================================

# Mode dev local : chemin vers le fichier SQLite. Lecture/écriture via
# libsql client en mode `file:` (synchrone côté disque mais API async).
DB_PATH=../data/baloo.db

# Mode prod (Turso) : URL libsql + token. Si DB_URL est défini,
# DB_PATH est ignoré.
# DB_URL=libsql://<groupe>.turso.io
# DB_AUTH_TOKEN=<token-readwrite-Turso>

# ============================================================================
# Stockage justificatifs (chantier 7, ADR-018)
# ============================================================================

# Mode dev / VPS : dossier filesystem (gitignored).
JUSTIFICATIFS_DIR=../justificatifs

# Mode Vercel serverless : token Vercel Blob. Si défini, le service
# bascule automatiquement sur @vercel/blob (filesystem éphémère sur
# Vercel rend FS inutilisable).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
