# Web (Next.js) — variables d'environnement (chantier 4, ADR-014).
# Renseigner dans web/.env.local (gitignored). Ce fichier sert de template.

# Auth.js v5 — secret de signature des cookies de session.
# Générer une chaîne aléatoire : `openssl rand -base64 32`
# En dev sans secret, Auth.js refuse de démarrer.
AUTH_SECRET=

# Email transport (magic link).
# - Sans EMAIL_SERVER : le lien magic link est loggé sur stderr (mode dev).
# - Avec EMAIL_SERVER : nodemailer envoie un vrai email (prod).
# Format : "smtp://user:pass@host:port" ou objet Nodemailer.
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=baloo@example.fr

# Chemin vers la BDD partagée (par défaut ../data/baloo.db).
# DB_PATH=../data/baloo.db
