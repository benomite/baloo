# Secrets
.env
.env.*
!.env.example
!**/.env.example
*.key
*.pem
secrets/

# Données spécifiques au groupe ou au user (ADR-013)
# Tout ce qui est user/groupe-dépendant vit en BDD ou en fichiers locaux,
# jamais en git. Aucune exception, même temporaire.
mon-groupe/

# Motifs de secrets custom pour le pre-commit hook (voir scripts/git-hooks/)
scripts/git-hooks/secrets-patterns.local

# Zone de dépôt brute (pièces sensibles, pas de versioning)
inbox/

# Pièces justificatives et exports
*.pdf
*.xlsx
*.xls
*.csv
*.ods
!doc/**/*.pdf
# Modèles SGDF servis statiquement par l'app web (formulaires vides,
# notices) — pas de données perso, OK à versionner.
!web/public/docs/*.pdf
!web/public/docs/*.xlsx

# Données perso / financières extraites
*.rib
mon-groupe/exports/

# Système
.DS_Store
Thumbs.db

# Éditeurs
.vscode/*
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Node
node_modules/

# SQLite database (dossier racine seulement — ne pas ignorer
# `web/src/lib/db.ts` ou autres `data/` profondément imbriqués si jamais)
/data/
*.db
*.db-wal
*.db-shm

# Sessions Comptaweb persistées + autres fichiers volatiles côté webapp
# (cf. `web/src/lib/comptaweb/session-store.ts` qui crée le dossier).
/web/data/

# Justificatifs (fichiers pièces jointes uploadés, racine seulement —
# ne pas ignorer la route `web/src/app/api/justificatifs/`)
/justificatifs/

# Temp
tmp/
.tmp/
