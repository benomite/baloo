# Variables d'environnement pour les MCP servers configurés dans
# `.mcp.json` (Airtable, Google Workspace). À renseigner dans `.env`
# (gitignored) à la racine du repo.
#
# Les variables côté `compta/` (MCP baloo-compta) sont dans
# `compta/.env.example`. Les variables côté `web/` (Next.js) sont dans
# `web/.env.example`.

# Airtable (MCP HTTP) — voir doc/integrations.md
# Personal Access Token avec scope lecture sur les bases concernées.
AIRTABLE_PAT=

# Google Workspace MCP (taylorwilsdon/google_workspace_mcp, lancé via uvx) —
# voir doc/integrations.md
# Création OAuth client : https://console.cloud.google.com/apis/credentials
# Scopes nécessaires : gmail.readonly, drive.readonly, spreadsheets.readonly
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
