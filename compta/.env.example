# Contexte Baloo (cf. ADR-013) - requis au bootstrap et à chaque run.
# Utilisé pour identifier le groupe et le user courants (pas d'auth active au MVP).
# Toutes ces valeurs sont user/groupe-dépendantes : laisser vides dans ce template,
# les renseigner uniquement dans compta/.env (gitignored).
BALOO_GROUP_CODE=
BALOO_GROUP_NAME=
BALOO_GROUP_TERRITOIRE=
BALOO_GROUP_EMAIL_CONTACT=
BALOO_USER_EMAIL=
BALOO_USER_NAME=

# Comptaweb - client API (cf. doc/comptaweb-api.md, ADR-012)
#
# COMPTAWEB_COOKIE : chaîne complète à envoyer dans le header Cookie.
# Copie-la depuis ton navigateur logué sur https://sgdf.production.sirom.net :
#   devtools > Application > Cookies > sirom.net > colonne Name + Value
# Si plusieurs cookies sont posés par le domaine, concatène-les sous la forme :
#   name1=value1; name2=value2
#
# Le cookie expire après quelques heures/jours. Il faudra le recopier à expiration.
# Une auth automatisée est prévue dans la roadmap.
COMPTAWEB_COOKIE=

# Optionnel - à ne surcharger que si l'instance change.
# COMPTAWEB_BASE_URL=https://sgdf.production.sirom.net
